{
  "name": "bv-awal-generator",
  "version": "0.1.0",
  "description": "Generates BV AWAL (Backup Volume) Excel workbooks for construction CCO backup documentation.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:client": "vite build --watch",
    "dev": "npm run build:client && wrangler dev",
    "build:client": "vite build",
    "deploy": "npm run build:client && wrangler deploy",
    "db:migrate:local": "wrangler d1 execute bv_awal_db --local --file=migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute bv_awal_db --remote --file=migrations/0001_init.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "exceljs": "^4.4.0",
    "hono": "^4.12.29",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260711.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "wrangler": "^4.110.0"
  }
}
